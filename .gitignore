# Compiled wasm artifacts. A published .wasm is built in CI from the reproducible
# build scripts and is never committed; the ArtifactId (sha256) is what gets pinned.
*.wasm

# Build output directories, one per toolchain.
build/
target/

# Installed dependencies, restored by the package manager.
node_modules/

# TinyGo intermediate build directory.
.tinygo-tmp/

# Distribution output (generated by CI, never committed).
dist/

# Codec verification files produced by reproducible-build checks.
*.verify*

# macOS metadata files.
.DS_Store
